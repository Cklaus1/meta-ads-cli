# ── Authentication ────────────────────────────────────────
# Meta App credentials (from developers.facebook.com)
# META_ADS_CLI_APP_ID=your_app_id_here
# META_ADS_CLI_APP_SECRET=your_app_secret_here

# Direct access token (bypasses OAuth flow)
# META_ADS_CLI_ACCESS_TOKEN=

# ── API Configuration ────────────────────────────────────
# Default ad account ID (format: act_XXXXXXXXX)
# META_ADS_CLI_ACCOUNT_ID=act_123456789

# Graph API version (default: v24.0)
# META_ADS_CLI_API_VERSION=v24.0

# ── Logging ──────────────────────────────────────────────
# Log level: debug, info, warn, error, none (default: none)
# META_ADS_CLI_LOG_LEVEL=none

# Log file path (enables JSON file logging with daily rotation)
# META_ADS_CLI_LOG_FILE=/tmp/meta-ads-cli.log

# ── Alternate Variable Names ─────────────────────────────
# These common Meta env vars are also accepted as fallbacks
# META_ACCESS_TOKEN=
# META_APP_ID=
# META_APP_SECRET=
