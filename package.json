{
  "name": "meta-ads-cli",
  "version": "0.1.0",
  "description": "A standalone CLI for Meta Ads (Facebook/Instagram) via the Graph API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "meta-ads": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "meta",
    "facebook",
    "instagram",
    "ads",
    "cli",
    "graph-api",
    "advertising"
  ],
  "license": "CC-BY-NC-4.0",
  "dependencies": {
    "commander": "^11.1.0",
    "dotenv": "^17.3.1",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.15",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
